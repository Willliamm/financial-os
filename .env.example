# Financial OS — public configuration (no secrets; these ship to the browser).
#
# Leave NEXT_PUBLIC_GOOGLE_CLIENT_ID empty to run fully offline in demo mode
# with in-memory mock Google clients and seeded sample data.
#
# To use real Google Sheets/Drive, create an OAuth 2.0 Web client in Google
# Cloud Console, add your origin to the authorized JavaScript origins, enable
# the Drive and Sheets APIs, and put the client id here.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

NEXT_PUBLIC_APP_NAME=Financial OS
NEXT_PUBLIC_DEFAULT_SCHEMA_VERSION=3

# Force mock Google clients even if a client id is set (useful for demos/tests).
# NEXT_PUBLIC_USE_MOCK_GOOGLE=true

# For GitHub Pages project sites only, e.g. "/financial-os".
# NEXT_PUBLIC_BASE_PATH=
